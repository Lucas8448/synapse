#!/usr/bin/env bash
# spine-sync — symlink adapters, validate env, (re)start the gateway.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${SYNAPSE_ENV:-$HOME/.config/synapse/.env}"
[[ -f "$ENV_FILE" ]] || ENV_FILE="$REPO/env/.env"   # fallback: gitignored repo env
PORT="${SYNAPSE_PORT:-4000}"

log() { printf '\033[1;36m[synapse]\033[0m %s\n' "$*"; }
die() { printf '\033[1;31m[synapse]\033[0m %s\n' "$*" >&2; exit 1; }

# 1. Env ----------------------------------------------------------------
[[ -f "$ENV_FILE" ]] || die "missing $ENV_FILE — cp env/.env.example there and fill in keys"
# parse KEY=VALUE lines instead of sourcing — a malformed line must never execute
while IFS= read -r line; do
  [[ "$line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]] || continue
  key="${line%%=*}"
  val="${line#*=}"
  val="${val%\"}"; val="${val#\"}"; val="${val%\'}"; val="${val#\'}"
  export "$key=$val"
done < "$ENV_FILE"
for key in LITELLM_MASTER_KEY; do
  [[ -n "${!key:-}" ]] || die "$key is empty in $ENV_FILE"
done
[[ -n "${OPENROUTER_API_KEY:-}" ]] || log "warn: OPENROUTER_API_KEY empty — all remote tiers will fail until set"

# Expose MCP tools as synapse_<tool> (underscore): models emit hyphenated
# function names unreliably, so keep the prefix separator LLM-friendly.
export MCP_TOOL_PREFIX_SEPARATOR="${MCP_TOOL_PREFIX_SEPARATOR:-_}"

# Filesystem MCP root — the read-only files tools auto-attach to capable tiers.
# Override in .env to widen/narrow scope (⚠️ read access + web fetch is a
# theoretical exfiltration path; point this at a code dir, not secrets).
export SYNAPSE_FILES_ROOT="${SYNAPSE_FILES_ROOT:-$HOME}"

# GitHub remote MCP token — refresh from the user's gh if available (the value
# carries the 'Bearer ' prefix, since litellm's bearer_token auth path is broken).
if command -v gh >/dev/null 2>&1 && gh auth token >/dev/null 2>&1; then
  export GITHUB_MCP_TOKEN="Bearer $(gh auth token)"
fi
[[ -n "${GITHUB_MCP_TOKEN:-}" ]] || log "warn: GITHUB_MCP_TOKEN unset — github MCP tools will 401 until you 'gh auth login' or set it in $ENV_FILE"

# 2. Adapters -----------------------------------------------------------
# Each dir under adapters/ has a `target` file: the path its contents symlink into.
for dir in "$REPO"/adapters/*/; do
  [[ -f "$dir/target" ]] || continue
  target="$(eval echo "$(cat "$dir/target")")"   # expand ~ and $VARS
  mkdir -p "$target"
  find "$dir" -maxdepth 1 -type f ! -name target | while read -r f; do
    ln -sfn "$f" "$target/$(basename "$f")"
    log "linked $(basename "$dir")/$(basename "$f") -> $target/"
  done
done

# 3. Gateway config -----------------------------------------------------
# litellm resolves callback modules relative to the config file's dir, so the
# gateway config AND its proxy callbacks must sit together where the config is
# loaded from. launchd loads ~/.config/synapse/litellm.yaml; link both there.
mkdir -p "$HOME/.config/synapse"
ln -sfn "$REPO/gateway/litellm.yaml" "$HOME/.config/synapse/litellm.yaml"
ln -sfn "$REPO/gateway/mcp_autoinject.py" "$HOME/.config/synapse/mcp_autoinject.py"
log "linked gateway config + callbacks -> ~/.config/synapse/"

# 4. Gateway ------------------------------------------------------------
LITELLM="$REPO/.venv/bin/litellm"                       # prefer repo venv
command -v "$LITELLM" >/dev/null || LITELLM="litellm"   # else PATH
command -v "$LITELLM" >/dev/null || die "litellm not found — .venv/bin/pip install 'litellm[proxy]'"
if pids="$(lsof -ti tcp:"$PORT" 2>/dev/null)" && [[ -n "$pids" ]]; then
  log "stopping gateway on :$PORT"
  while IFS= read -r pid; do [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true; done <<<"$pids"
  sleep 1
fi
log "starting gateway on :$PORT"
mkdir -p "$HOME/.config/synapse"
cd "$REPO" # stdio MCP servers resolve repo-relative paths (./.venv/bin/python, memory/server.py)
nohup "$LITELLM" --config "$REPO/gateway/litellm.yaml" --host 127.0.0.1 --port "$PORT" \
  > "$HOME/.config/synapse/gateway.log" 2>&1 &

for _ in $(seq 1 30); do
  sleep 1
  if curl -sf "http://localhost:$PORT/health/liveliness" >/dev/null 2>&1; then
    log "gateway healthy — tiers: frontier | mid | bulk | low | local"
    exit 0
  fi
done
die "gateway not up after 30s — tail -30 ~/.config/synapse/gateway.log"
