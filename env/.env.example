# Copy to ~/.config/synapse/.env and fill in. NEVER commit real keys.
# spine-sync sources this file before starting the gateway.

OPENROUTER_API_KEY=   # sole provider key — all tiers route through OpenRouter
LITELLM_MASTER_KEY=   # any non-empty secret, e.g. `openssl rand -hex 16`

# Optional overrides
# OLLAMA_API_BASE=http://localhost:11434
# SYNAPSE_VAULT=~/path/to/Obsidian Vault   # notes indexed by the synapse memory MCP server
# SYNAPSE_FILES_ROOT=~/code                 # root for the read-only filesystem MCP server (default: $HOME)
# GITHUB_MCP_TOKEN=Bearer ghu_xxx           # GitHub remote MCP; auto-set from `gh auth token` when gh is logged in
